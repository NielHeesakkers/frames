# .env.example — copy to .env and fill in real values. DO NOT commit .env.
FRAMES_SESSION_SECRET=generate-with-openssl-rand-base64-32
FRAMES_PUBLIC_URL=http://localhost:8080
FRAMES_ADMIN_USERNAME=admin
FRAMES_ADMIN_PASSWORD=change-me-at-least-12-chars

# Path to your photo library on the host. Default is ./photos (relative to compose file).
# On a server you'll probably want an absolute path, e.g. /mnt/photos or /srv/library.
FRAMES_PHOTOS_HOST_PATH=./photos

# Trust X-Forwarded-For when behind a reverse proxy (Caddy/Traefik/nginx).
# Enable this ONLY if frames is not directly exposed to the internet.
FRAMES_TRUST_PROXY=0
